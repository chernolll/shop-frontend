{
  "api": "GET /bd/my-tasks",
  "description": "BD用户-我的任务列表",

  "request": {
    "params": {
      "page": { "type": "number", "required": true, "description": "页码，从1开始" },
      "pageSize": { "type": "number", "required": true, "description": "每页条数" },
      "productName": { "type": "string", "required": false, "description": "商品名称模糊搜索" },
      "prepareStatus": { "type": "string", "required": false, "description": "筹备状态筛选", "enum": ["NOT_STARTED", "IN_PROGRESS", "PARTIAL", "DONE"] },
      "deadlineStart": { "type": "string", "required": false, "description": "截止时间起始，ISO date" },
      "deadlineEnd": { "type": "string", "required": false, "description": "截止时间结束，ISO date" }
    }
  },

  "response": {
    "items": [
      {
        "taskId": { "type": "number", "description": "任务ID，同时也是表格行key" },
        "productName": { "type": "string", "description": "商品名称" },
        "productImage": { "type": "string", "description": "商品图片URL" },
        "shopName": { "type": "string", "description": "店铺名称" },
        "platform": { "type": "number", "description": "平台", "enum": { "1": "TikTok", "2": "Shopee", "3": "Lazada" } },
        "country": { "type": "string", "description": "国家/站点代码，如TH、CN" },
        "commission": { "type": "number", "description": "佣金（任务固定佣金）" },
        "myVideoNum": { "type": "number", "description": "当前BD负责的视频数量" },
        "totalVideoNum": { "type": "number", "description": "该任务总视频数量" },
        "preparePassed": { "type": "number", "description": "已通过筹备的达人数量" },
        "preparePending": { "type": "number", "description": "待审核的达人数量" },
        "prepareTotal": { "type": "number", "description": "筹备达人总数" },
        "progress": { "type": "number", "description": "筹备进度百分比，0-100的整数" },
        "prepareStatus": { "type": "string", "description": "筹备状态", "enum": ["NOT_STARTED", "IN_PROGRESS", "PARTIAL", "DONE"] },
        "deadline": { "type": "string", "description": "截止日期，ISO date格式" },
        "followEntryTime": { "type": "string", "description": "BD跟进录入时间，ISO datetime格式" },
        "taskType": { "type": "number", "description": "任务类型", "enum": { "0": "定制", "1": "公开" } }
      }
    ],
    "total": { "type": "number", "description": "总记录数，用于分页" }
  },

